# Nasdaq Risk Radar — Environment Variables

# Groq AI — clasificación de noticias + chat (REQUERIDO)
# Gratis en: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Finnhub — noticias raw + precios en tiempo real (REQUERIDO para datos reales)
# Gratis en: https://finnhub.io/dashboard
FINNHUB_KEY=your_finnhub_key_here

# FRED — datos macro de la Fed (opcional, pestaña Fed/Macro)
# Gratis en: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_key_here

# Sin keys: el radar funciona con datos de demo realistas
